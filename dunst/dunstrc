[global]
    monitor                = 0
    follow                 = none
    width                  = 300
    height                 = 80
    origin                 = top-right
    offset                 = 10x10
    scale                  = 0
    notification_limit     = 5
    progress_bar           = true
    progress_bar_height    = 6
    progress_bar_frame_width = 0
    progress_bar_min_width = 260
    progress_bar_max_width = 260
    progress_bar_corner_radius = 3
    indicate_hidden        = yes
    transparency           = 0
    separator_height       = 1
    padding                = 10
    horizontal_padding     = 12
    text_icon_padding      = 8
    frame_width            = 1
    frame_color            = "#44475a"
    gap_size               = 6
    separator_color        = frame
    sort                   = yes
    idle_threshold         = 120
    font                   = Monospace 10
    line_height            = 0
    markup                 = full
    format                 = "<b>%s</b>\n%b"
    alignment              = left
    vertical_alignment     = center
    show_age_threshold     = -1
    ellipsize              = middle
    ignore_newline         = no
    stack_duplicates       = true
    hide_duplicate_count   = false
    show_indicators        = no
    enable_recursive_icon_lookup = true
    icon_corner_radius     = 4
    icon_theme             = Papirus, Adwaita
    icon_position          = left
    min_icon_size          = 32
    max_icon_size          = 32
    sticky_history         = yes
    history_length         = 20
    dmenu                  = /usr/bin/dmenu -p dunst
    browser                = /usr/bin/xdg-open
    always_run_script      = true
    title                  = Dunst
    class                  = Dunst
    corner_radius          = 8
    ignore_dbusclose       = false
    force_xwayland         = false
    force_xinerama         = false
    mouse_left_click       = close_current
    mouse_middle_click     = do_nothing
    mouse_right_click      = close_all

[urgency_low]
    background             = "#1e1e2e"
    foreground             = "#cdd6f4"
    frame_color            = "#313244"
    progress_bar_color     = "#89b4fa"
    timeout                = 2

[urgency_normal]
    background             = "#1e1e2e"
    foreground             = "#cdd6f4"
    frame_color            = "#313244"
    progress_bar_color     = "#a6e3a1"
    timeout                = 5

[urgency_high]
    background             = "#1e1e2e"
    foreground             = "#f38ba8"
    frame_color            = "#f38ba8"
    progress_bar_color     = "#f38ba8"
    timeout                = 0
